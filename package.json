{
  "name": "@ton/sandbox",
  "version": "0.43.0",
  "description": "TON transaction emulator",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ton-org/sandbox.git"
  },
  "license": "MIT",
  "author": {
    "name": "TonTech",
    "url": "https://ton.tech"
  },
  "maintainers": [
    {
      "name": "TON Core"
    }
  ],
  "main": "dist/index.js",
  "files": [
    "jest-environment.js",
    "jest-reporter.js",
    "dist/**/*"
  ],
  "scripts": {
    "build": "rm -rf dist && bun run wasm:pack && tsc && bun run wasm:copy",
    "config:pack": "ts-node ./scripts/pack-config.ts",
    "fmt": "biome format --write .",
    "fmt:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "test": "bun run wasm:pack && jest src",
    "wasm:copy": "cp src/executor/emulator-emscripten.js src/executor/emulator-emscripten.wasm.js ./dist/executor",
    "wasm:pack": "ts-node ./scripts/pack-wasm.ts"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "table": "^6.9.0",
    "ton-assembly": "0.6.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@ton-community/func-js": "^0.10.0",
    "@ton/core": "^0.61.0",
    "@ton/crypto": "3.3.0",
    "@ton/test-utils": "^0.7.0",
    "@ton/tolk-js": "^1.0.0",
    "@ton/ton": "^15.2.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.1.0",
    "jest": "^30.0.5",
    "jest-config": "^30.0.5",
    "jest-environment-node": "^30.0.5",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "@ton-community/func-js": ">=0.10.0",
    "@ton/core": ">=0.61.0",
    "@ton/crypto": ">=3.3.0",
    "@ton/test-utils": ">=0.7.0",
    "jest": "^29.5.0 || ^30.0.5"
  },
  "peerDependenciesMeta": {
    "@ton/test-utils": {
      "optional": true
    },
    "jest": {
      "optional": true
    }
  }
}
